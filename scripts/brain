#!/usr/bin/env bash
# brain CLI v2.0 — shell front-end for /root/brain.
# Documented in /root/brain/docs/architecture/README.md.
set -u
BRAIN_DIR="/root/brain"
BRAIN_VERSION_FILE="$BRAIN_DIR/VERSION.md"
BRAIN_BACKUP="$BRAIN_DIR/scripts/maintenance/backup-all.sh"
BRAIN_SELFDEPLOY="$BRAIN_DIR/scripts/maintenance/self-deploy.sh"

usage() {
cat <<'HELP'
🧠 Brain CLI v2.1

CORE
  brain "idea"          New idea → analysis (Шефа Симо orchestrates)
  brain status          Brain status snapshot
  brain projects        Active projects
  brain ideas           Idea queue
  brain agents          Agent count
  brain skills          Skills loaded
  brain version         Show version
  brain logs            Recent routine logs

V2.1 LIVE EMPIRE
  brain heartbeat       Live agent health (alive/sleeping/dead)
  brain tokens          Token usage per agent today
  brain money           Money dashboard (revenue + tokens + goals)
  brain opportunities   Top opportunities from money-hunter
  brain crypto          Crypto module status (paper mode)
  brain modules         List Brain modules
  brain agents-talk     Tail message bus
  brain keys            API keys status (no values shown)
  brain chat            Open chat with Шефа Симо
  brain pause-agent <N> Pause one agent (save tokens)
  brain resume-agent <N> Resume paused agent

DEEP WORK
  brain ultrathink "X"  Einstein mode
  brain audit <proj>    Full project audit
  brain deploy <proj>   Deploy with checks
  brain learn "topic"   Deep research (10+ sources)
  brain memory <query>  Search memory (grep + Supabase)

OPS
  brain backup          Tar + push everything
  brain upgrade         Pull latest from origin/main
  brain compact         Compact context (save first)
HELP
}

cmd="${1:-}"
shift 2>/dev/null || true

case "$cmd" in
  ""|"-h"|"--help") usage ;;
  "status")
    /root/.claude/statusline.sh
    echo
    echo "--- PM2 ---"
    pm2 status 2>/dev/null | tail -n +4 | head -8 || true
    echo "--- Disk ---"
    df -h "$BRAIN_DIR" | tail -1
    echo "--- Sites ---"
    for u in https://app.svd-clean.de https://demo.svd-clean.de https://brain.svd-clean.de; do
      c=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$u" || echo "000")
      printf "  %s  %s\n" "$c" "$u"
    done
    ;;
  "projects")
    if [ -d "$BRAIN_DIR/projects" ]; then ls -1 "$BRAIN_DIR/projects" 2>/dev/null || true; fi
    ;;
  "ideas")
    [ -f "$BRAIN_DIR/memory/ideas-queue.md" ] && cat "$BRAIN_DIR/memory/ideas-queue.md" || echo "(no /root/brain/memory/ideas-queue.md yet)"
    ;;
  "agents") echo "$(ls /root/.claude/agents 2>/dev/null | wc -l) agents installed in ~/.claude/agents/" ;;
  "skills") ls /root/.claude/skills 2>/dev/null || echo "(no skills)" ;;
  "memory")
    q="${1:-}"
    [ -z "$q" ] && { echo "Usage: brain memory <query>"; exit 1; }
    grep -ri --include='*.md' "$q" "$BRAIN_DIR/memory/" 2>/dev/null | head -30 || echo "(no matches)"
    ;;
  "ultrathink")
    q="$*"
    [ -z "$q" ] && { echo "Usage: brain ultrathink \"<question>\""; exit 1; }
    cd "$BRAIN_DIR" && claude -p "/ultrathink $q" --max-turns 30
    ;;
  "audit")
    p="${1:-}"
    [ -z "$p" ] && { echo "Usage: brain audit <project>"; exit 1; }
    cd "$BRAIN_DIR" && claude -p "/audit $p" --max-turns 30
    ;;
  "deploy")
    p="${1:-}"
    [ -z "$p" ] && { echo "Usage: brain deploy <project>"; exit 1; }
    cd "$BRAIN_DIR" && claude -p "/deploy $p" --max-turns 30
    ;;
  "learn")
    q="$*"
    [ -z "$q" ] && { echo "Usage: brain learn \"<topic>\""; exit 1; }
    cd "$BRAIN_DIR" && claude -p "/learn $q" --max-turns 30
    ;;
  "backup")
    [ -x "$BRAIN_BACKUP" ] && bash "$BRAIN_BACKUP" || echo "(backup script not yet installed — see ETAP 18)"
    ;;
  "upgrade")
    cd "$BRAIN_DIR" || exit 1
    git fetch origin --quiet
    LOCAL=$(git rev-parse HEAD)
    REMOTE=$(git rev-parse origin/main)
    if [ "$LOCAL" != "$REMOTE" ]; then
      echo "🔄 Upgrading Brain ($LOCAL → $REMOTE)…"
      git pull --rebase origin main
      [ -f dashboard/package.json ] && (cd dashboard && pnpm install --no-frozen-lockfile && pnpm build)
      pm2 restart brain-dashboard 2>/dev/null || true
      echo "✅ Upgrade complete"
    else
      echo "✅ Already on latest ($LOCAL)"
    fi
    ;;
  "heartbeat")
    bash /root/brain/scripts/heartbeat.sh status 2>/dev/null | head -200
    ;;
  "tokens")
    if [ -x /root/brain/scripts/token-tracker.sh ]; then
      bash /root/brain/scripts/token-tracker.sh status 2>/dev/null
    else
      echo "(token-tracker.sh not installed)"
    fi
    ;;
  "money")
    cd "$BRAIN_DIR" && claude -p "/money" --max-turns 10 2>/dev/null || echo "(claude CLI unavailable)"
    ;;
  "opportunities")
    cd "$BRAIN_DIR" && claude -p "/opportunities" --max-turns 10 2>/dev/null || echo "(claude CLI unavailable)"
    ;;
  "crypto")
    cd "$BRAIN_DIR" && claude -p "/crypto" --max-turns 10 2>/dev/null || echo "(claude CLI unavailable)"
    ;;
  "modules")
    ls -1 /root/brain/modules/ 2>/dev/null || echo "(no modules dir)"
    ;;
  "agents-talk")
    bash /root/brain/scripts/message-bus.sh tail "${1:-30}" 2>/dev/null
    ;;
  "keys")
    echo "Configured API keys (status only, no values):"
    if [ -f /root/brain/.env.api-keys ]; then
      for k in RESEND_API_KEY BRAVE_SEARCH_API_KEY GMAIL_OAUTH_CLIENT_ID TELEGRAM_BOT_TOKEN OPENAI_API_KEY MEXC_API_KEY BINANCE_API_KEY REPLICATE_API_KEY ELEVENLABS_API_KEY RUNWAY_API_KEY; do
        val=$(grep "^${k}=" /root/brain/.env.api-keys | head -1 | cut -d= -f2-)
        if [ -n "$val" ] && [ "$val" != "" ]; then
          echo "  ✅ $k  (set, ${#val} chars)"
        else
          echo "  ⚪ $k  (empty)"
        fi
      done
    else
      echo "❌ /root/brain/.env.api-keys missing"
    fi
    ;;
  "chat")
    cd "$BRAIN_DIR" && claude -p "/chat" --max-turns 30
    ;;
  "pause-agent")
    a="${1:-}"
    [ -z "$a" ] && { echo "Usage: brain pause-agent <name>"; exit 1; }
    cd "$BRAIN_DIR" && claude -p "/pause-agent $a" --max-turns 10
    ;;
  "resume-agent")
    a="${1:-}"
    [ -z "$a" ] && { echo "Usage: brain resume-agent <name>"; exit 1; }
    cd "$BRAIN_DIR" && claude -p "/resume-agent $a" --max-turns 10
    ;;
  "version") cat "$BRAIN_VERSION_FILE" 2>/dev/null || echo "(version file missing)" ;;
  "logs")
    tail -50 "$BRAIN_DIR/logs/routines/"*.log 2>/dev/null || echo "(no routine logs yet)"
    ;;
  "compact")
    cd "$BRAIN_DIR" && claude -p "/compact"
    ;;
  *)
    IDEA="$cmd $*"
    [ -z "${IDEA// }" ] && { usage; exit 1; }
    TS=$(date +%s)
    PROJECT_ID="proj-$TS"
    mkdir -p "$BRAIN_DIR/projects/$PROJECT_ID"
    echo "🧠 Brain v2.0 — analysing…"
    echo "Project ID: $PROJECT_ID"
    cd "$BRAIN_DIR"
    claude -p "Шефе нова идея: '$IDEA'.

Project ID: $PROJECT_ID
Workspace:  /root/brain/projects/$PROJECT_ID/

Workflow (in parallel where independent):
1. shefe-validator → brutal go/no-go
2. If GO →
   - market-researcher
   - shefe-architect
   - shefe-lawyer
   - shefe-designer
   - shefe-marketer
   - shefe-engineer
3. Synthesise → save to /root/brain/projects/$PROJECT_ID/report.md
4. Insert into Supabase brain_ideas + brain_projects + brain_agent_log via Supabase MCP

Truth audit before any change. Auto YES allowed in /root.
End with a single mobile-friendly TL;DR." --max-turns 100
    echo
    echo "✅ Report at: /root/brain/projects/$PROJECT_ID/report.md"
    ;;
esac
