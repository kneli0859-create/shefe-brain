{
  "theme": "dark",
  "enabledPlugins": {
    "supabase@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "/root/.claude/statusline.sh"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /root)",
      "Bash(rm -rf /root/*)",
      "Bash(rm -rf /etc)",
      "Bash(rm -rf /etc/*)",
      "Bash(rm -rf /var)",
      "Bash(rm -rf /home)",
      "Bash(rm -rf /usr)",
      "Bash(rm -rf /root/svd-clean-pro)",
      "Bash(rm -rf /root/svd-clean-pro/*)",
      "Bash(rm -rf /root/brain)",
      "Bash(rm -rf /root/brain/*)",
      "Bash(dd if=* of=/dev/sd*)",
      "Bash(mkfs* /dev/*)",
      "Bash(:(){ :|:& };:)",
      "Bash(git push --force origin main)",
      "Bash(git push --force-with-lease origin main)",
      "Bash(git push -f origin main)",
      "Bash(git remote remove origin)",
      "Bash(rm -rf .git)"
    ]
  }
}
