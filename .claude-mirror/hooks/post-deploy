#!/usr/bin/env bash
# post-deploy hook — wait 30s for warm-up, smoke test, auto-rollback on failure.
set -u

TARGETS=(
  "https://app.svd-clean.de"
  "https://demo.svd-clean.de"
)
[ -n "${BRAIN_DEPLOYED:-}" ] && TARGETS+=("https://brain.svd-clean.de")

echo "[post-deploy] waiting 30s for processes to settle…"
sleep 30

FAIL=0
for url in "${TARGETS[@]}"; do
  CODE=$(curl -s -o /dev/null -w "%{http_code}" --max-time 15 "$url" || echo "000")
  if [ "$CODE" != "200" ] && [ "$CODE" != "301" ] && [ "$CODE" != "302" ]; then
    echo "[post-deploy] ❌ $url returned $CODE"
    FAIL=1
  else
    echo "[post-deploy] ✅ $url $CODE"
  fi
done

if [ "$FAIL" -eq 1 ]; then
  echo "[post-deploy] 🚨 Smoke test failed — attempting auto-rollback in /root/svd-clean-pro"
  cd /root/svd-clean-pro 2>/dev/null && git revert HEAD --no-edit && pm2 restart svd-clean-app svd-clean-demo
  exit 1
fi

# Trigger learning loop (non-blocking) — only if `claude` CLI is present.
if command -v claude >/dev/null 2>&1; then
  ( cd /root/brain && claude -p "Post-deploy reflection. What changed in the last commit? Any lessons worth saving to /root/brain/memory/lessons.md?" --max-turns 5 ) >/dev/null 2>&1 &
fi
exit 0
